@startuml CheckInProcess
title Sequence Diagram - Check In Process (Nhận Xe Vào Bãi)

actor Staff as "Nhân viên"
participant CheckInPanel as "UI: CheckInPanel"
participant CheckInService as "Service: CheckInService"
participant DataStorage as "Storage: DataStorage"
participant SubscriptionCard as "Card: SubscriptionCard"
participant ParkingSlot as "Slot: ParkingSlot"
participant ParkingTicket as "Ticket: ParkingTicket"

Staff -> CheckInPanel: Nhập thông tin (Biển số, Loại xe, Mã thẻ) & bấm "Check In"
activate CheckInPanel

CheckInPanel -> CheckInService: performCheckIn(plate, type, idCard)
activate CheckInService

alt idCard != null (Có sử dụng thẻ tháng)
    CheckInService -> DataStorage: getListCards()
    activate DataStorage
    DataStorage --> CheckInService: List<SubscriptionCard>
    deactivate DataStorage
    
    CheckInService -> SubscriptionCard: filter() & kiểm tra hợp lệ
    activate SubscriptionCard
    SubscriptionCard --> CheckInService: result
    deactivate SubscriptionCard
    
    alt Thẻ không hợp lệ
        CheckInService --> CheckInPanel: "The thang khong hop le"
    end
end

CheckInService -> DataStorage: getListSlots()
activate DataStorage
DataStorage --> CheckInService: List<ParkingSlot>
deactivate DataStorage

CheckInService -> ParkingSlot: Tìm vị trí trống (availableSlot) theo loại xe
activate ParkingSlot
ParkingSlot --> CheckInService: availableSlot
deactivate ParkingSlot

alt availableSlot == null (Hết chỗ)
    CheckInService --> CheckInPanel: "Het cho do cho loai xe..."
else Có chỗ trống
    CheckInService -> ParkingSlot: setOccupied(true)
    
    CheckInService -> ParkingTicket: new ParkingTicket(ticketId, plate, type, time, ...)
    activate ParkingTicket
    ParkingTicket --> CheckInService: ticket
    deactivate ParkingTicket
    
    CheckInService -> DataStorage: getListTickets()
    activate DataStorage
    DataStorage --> CheckInService: List<ParkingTicket>
    deactivate DataStorage
    
    CheckInService -> DataStorage: add(ticket)
    
    CheckInService --> CheckInPanel: "Check-in thanh cong..."
end

deactivate CheckInService

CheckInPanel --> Staff: Hiển thị thông báo
deactivate CheckInPanel

@enduml

